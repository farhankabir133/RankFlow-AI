rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all Default-Deny Security rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validator logic for UserProfile
    function isValidUserProfile(data) {
      return data.name is string && data.name.size() <= 128
        && data.examType is string && (data.examType == 'BCS' || data.examType == 'Admission' || data.examType == 'SSC' || data.examType == 'HSC')
        && data.streak is int && data.streak >= 0
        && data.xp is int && data.xp >= 0
        && data.level is int && data.level >= 0;
    }

    // Rules for /users/{userId}
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if isOwner(userId);
    }

    // Rules for /analytics/{userId}
    match /analytics/{userId} {
      allow get: if isOwner(userId);
      allow write: if isOwner(userId) && isValidId(userId);
    }

    // Rules for /memory/{userId}
    match /memory/{userId} {
      allow get: if isOwner(userId);
      allow write: if isOwner(userId) && isValidId(userId);
    }

    // Rules for /circulars/{circularId}
    match /circulars/{circularId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable server-side by system
    }
  }
}
