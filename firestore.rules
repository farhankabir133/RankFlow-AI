rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profile document ──────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ── Exam sessions sub-collection ─────────────────────────────────────
      match /examSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Spaced revision items sub-collection ─────────────────────────────
      match /revisionItems/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Aggregated analytics document ─────────────────────────────────────
      match /analytics/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Legacy progress path (kept for backwards compat) ──────────────────
      match /progress/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Rules for /analytics/{userId}
    match /analytics/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for /memory/{userId}
    match /memory/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for /circulars/{circularId}
    match /circulars/{circularId} {
      allow read: if request.auth != null;
      allow write: if false; // Only manageable server-side by system
    }

    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
